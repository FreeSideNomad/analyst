# analyst — local configuration for docker compose (cp .env.example .env).
# .env is gitignored; never commit real values.

# Host port the app is published on (container always listens on 8000).
ANALYST_PORT=8000

# Image to run. Default builds locally from ./Dockerfile; point at
# ghcr.io/freesidenomad/analyst:latest to run the published image instead.
#ANALYST_IMAGE=analyst:local

# Enable LLM features (natural-language Q&A). Unset = fully local, no
# external calls. Raw bulk data never leaves the box either way.
# Provide ONE of: an API key, or a Claude subscription token (the host's
# Keychain login does not reach into the container — run `claude setup-token`).
#ANTHROPIC_API_KEY=sk-ant-...
#CLAUDE_CODE_OAUTH_TOKEN=

# "live" = agent-written catalog descriptions at ingest (needs the API key).
#ANALYST_CATALOG=live

# Operator key that encrypts stored database credentials at rest.
# Any strong passphrase; losing it means re-entering DB credentials.
#ANALYST_SECRET_KEY=change-me
